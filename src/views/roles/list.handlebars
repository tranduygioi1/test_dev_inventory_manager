<div class="mb-6 flex justify-between items-center">
    <h2 class="text-2xl font-bold">Quản Lý Vai Trò (Roles) & Quyền (Permissions)</h2>
    <button onclick="document.getElementById('createRoleModal').classList.remove('hidden')" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-md font-medium transition">
        + Thêm Vai Trò Mới
    </button>
</div>

<div class="space-y-6">
    {{#each roles}}
    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 shadow-sm relative">
        <div class="flex justify-between items-start mb-4">
            <div>
                <h3 class="text-xl font-bold text-gray-800">{{this.name}}</h3>
                <p class="text-gray-500 text-sm">{{this.description}}</p>
            </div>
            {{#if (eq this.name 'admin')}}
            <span class="text-gray-400 text-sm italic">Role hệ thống (Không thể xóa)</span>
            {{else}}
            <button onclick="deleteRole('{{this.id}}')" class="text-red-500 hover:text-red-700 font-medium text-sm">Xóa Role</button>
            {{/if}}
        </div>

        <form action="/roles/{{this.id}}/permissions" method="POST" class="mt-4">
            <h4 class="font-semibold text-gray-700 mb-2">Quyền Hạn:</h4>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-4">
                {{#each this.permissions}}
                <label class="flex items-center space-x-2 cursor-pointer">
                    <input type="checkbox" name="permissions" value="{{this.id}}" class="form-checkbox h-4 w-4 text-purple-600 rounded"
                    {{#if this.hasPermission}}checked{{/if}}
                    {{#if (eq ../name 'admin')}}disabled{{/if}}>
                    <span class="text-gray-700 text-sm">{{this.name}}</span>
                </label>
                {{/each}}
            </div>
            
            {{#if (eq this.name 'admin')}}
            <!-- Cannot edit admin role -->
            {{else}}
            <div class="flex justify-end">
                <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium transition">
                    Cập nhật quyền
                </button>
            </div>
            {{/if}}
        </form>
    </div>
    {{/each}}
</div>

<!-- Create Role Modal -->
<div id="createRoleModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full flex justify-center items-center z-50">
    <div class="bg-white p-8 rounded-md shadow-xl w-96 relative">
        <button onclick="document.getElementById('createRoleModal').classList.add('hidden')" class="absolute top-2 right-4 text-gray-500 hover:text-gray-700 font-bold text-xl">&times;</button>
        <h3 class="text-xl font-bold mb-4">Thêm Vai Trò Mới</h3>
        <form action="/roles/create" method="POST">
            <div class="mb-4">
                <label class="block text-gray-700 text-sm font-bold mb-2">Tên Vai Trò (VD: ketoan, thukho)</label>
                <input type="text" name="name" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" required>
            </div>
            <div class="mb-6">
                <label class="block text-gray-700 text-sm font-bold mb-2">Mô tả (Không bắt buộc)</label>
                <input type="text" name="description" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
            </div>
            <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded w-full focus:outline-none focus:shadow-outline transition">
                Tạo Vai Trò
            </button>
        </form>
    </div>
</div>

<script>
async function deleteRole(id) {
    if (confirm('Bạn có chắc chắn muốn xóa vai trò này? Hãy đảm bảo không có user nào đang giữ vai trò này.')) {
        try {
            const res = await fetch(`/roles/${id}`, { method: 'DELETE' });
            if (res.ok) {
                window.location.reload();
            } else {
                const data = await res.json();
                alert(data.error || 'Có lỗi xảy ra khi xóa!');
            }
        } catch (e) {
            console.error(e);
            alert('Lỗi kết nối!');
        }
    }
}
</script>
